  script.
    (() => {
      const root = document.getElementById('rolling-gallery')
      if (!root || root.dataset.bound === 'true') return
      root.dataset.bound = 'true'

      const track = root.querySelector('.rolling-track')
      const viewport = root.querySelector('.rolling-viewport')
      if (!track || !viewport) return

      const faceCount = track.querySelectorAll('.rolling-face').length
      const autoplay = root.dataset.autoplay === 'true'
      const pauseOnHover = root.dataset.pauseOnHover === 'true'

      let rotateY = 0
      let isPointerDown = false
      let isDragging = false
      let isHovered = false
      let startX = 0
      let startRot = 0
      let lastDragAt = 0
      let autoTimer = null

      const DRAG_FACTOR = 0.25
      const MOMENTUM = 0.1
      const STEP = 360 / faceCount
      const MOVE_THRESHOLD = 6

      const apply = () => {
        track.style.setProperty('--roll', `${rotateY}deg`)
      }

      const stopAuto = () => {
        if (!autoTimer) return
        clearInterval(autoTimer)
        autoTimer = null
      }

      const startAuto = () => {
        if (!autoplay) return
        stopAuto()
        autoTimer = setInterval(() => {
          if (isDragging || (pauseOnHover && isHovered)) return
          rotateY -= STEP
          apply()
        }, 2400)
      }

      const onDown = (clientX) => {
        isPointerDown = true
        isDragging = true
        startX = clientX
        startRot = rotateY
        track.classList.add('dragging')
        stopAuto()
      }

      const onMove = (clientX) => {
        if (!isPointerDown) return
        const delta = clientX - startX
        if (Math.abs(delta) <= 2) return
        rotateY = startRot + delta * DRAG_FACTOR
        apply()
      }

      const onUp = (clientX) => {
        if (!isPointerDown) return
        isPointerDown = false
        isDragging = false
        track.classList.remove('dragging')
        const dragDelta = clientX - startX
        if (Math.abs(dragDelta) > MOVE_THRESHOLD) lastDragAt = Date.now()
        const momentum = (clientX - startX) * MOMENTUM
        rotateY += momentum
        apply()

        if (autoplay && !(pauseOnHover && isHovered)) {
          setTimeout(() => startAuto(), 1200)
        }
      }

      viewport.addEventListener('pointerdown', (event) => {
        onDown(event.clientX)
      })

      window.addEventListener('pointermove', (event) => {
        onMove(event.clientX)
      })

      const handlePointerEnd = (event) => {
        onUp(event.clientX || startX)
      }

      window.addEventListener('pointerup', handlePointerEnd)
      window.addEventListener('pointercancel', handlePointerEnd)

      viewport.addEventListener('mouseenter', () => {
        isHovered = true
        if (pauseOnHover && autoplay) stopAuto()
      })

      viewport.addEventListener('mouseleave', () => {
        isHovered = false
        if (pauseOnHover && autoplay && !isDragging) startAuto()
      })

      viewport.addEventListener('wheel', (event) => {
        if (Math.abs(event.deltaX) <= Math.abs(event.deltaY)) return
        event.preventDefault()
        rotateY -= event.deltaX * 0.5
        apply()
      }, { passive: false })

      track.querySelectorAll('.rolling-face').forEach((face) => {
        face.addEventListener('click', (event) => {
          if (Date.now() - lastDragAt > 220) return
          event.preventDefault()
        })
      })

      if ('IntersectionObserver' in window) {
        new IntersectionObserver(([entry]) => {
          if (entry.isIntersecting && autoplay) startAuto()
          else stopAuto()
        }, { threshold: 0.2 }).observe(root)
      } else if (autoplay) {
        startAuto()
      }

      apply()
    })()
