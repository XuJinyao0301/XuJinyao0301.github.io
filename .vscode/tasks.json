{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build active C++ file",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.cpp-build\" && /usr/bin/clang++ -std=c++20 -g -Wall -Wextra -Wpedantic \"${file}\" -o \"${workspaceFolder}/.cpp-build/${fileBasenameNoExtension}\"",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc",
      "detail": "Compile the currently open C++ file with Apple clang++."
    }
  ]
}
